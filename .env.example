# Copy to .env (or export in your shell) and fill in.
ANTHROPIC_API_KEY=sk-ant-...
# Must be a valid Anthropic model id. Spec requested claude-sonnet-4-6;
# use claude-sonnet-5 (or another current id) if that is unavailable.
ANTHROPIC_MODEL=claude-sonnet-4-6
JWT_SECRET=change-me-to-a-long-random-string
# Local dev defaults (Docker/Cloud Run override these to /data/...)
DATABASE_PATH=./data/patent_drafter.db
UPLOAD_DIR=./data/uploads
PORT=8080
