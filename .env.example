# Copy to .env (or export in your shell) and fill in.
ANTHROPIC_API_KEY=sk-ant-...
# Must be a valid Anthropic model id. Spec requested claude-sonnet-4-6;
# use claude-sonnet-5 (or another current id) if that is unavailable.
ANTHROPIC_MODEL=claude-sonnet-4-6
JWT_SECRET=change-me-to-a-long-random-string

# --- Storage: Turso cloud database (libSQL) — REQUIRED -----------------------
# All persistence lives in Turso. There is no local SQLite file.
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Ephemeral scratch dir for uploaded .docx copies (disposable — the parsed text
# stored in Turso is the source of truth).
UPLOAD_DIR=./data/uploads
PORT=8080
